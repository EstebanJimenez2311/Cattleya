DJANGO_SECRET_KEY=replace-with-a-long-random-production-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=cattleya-backend.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://cattleyadata.netlify.app
DJANGO_CORS_ALLOWED_ORIGINS=https://cattleyadata.netlify.app
DJANGO_CORS_ALLOW_ALL_ORIGINS=False

# Base de datos de produccion en Render
DB_ENGINE=postgres
POSTGRES_DB=replace-with-render-postgres-db
POSTGRES_USER=replace-with-render-postgres-user
POSTGRES_PASSWORD=replace-with-render-postgres-password
POSTGRES_HOST=replace-with-render-postgres-host
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_SSLMODE=prefer

# Seguridad de produccion
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

# Auto-creacion de superusuario
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@cattleyadata.com
DJANGO_SUPERUSER_PASSWORD=replace-with-a-strong-admin-password

# Chatbot en produccion
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
CHATBOT_MAX_TURNS=4
CHATBOT_MAX_CHARS_PER_MESSAGE=500
CHATBOT_MAX_OUTPUT_TOKENS=220
